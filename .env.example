# =========================================
# PyBootCamp - Environment Variables Example
# Copy this file to .env.local and fill values
# =========================================

# --- Turso Database (SQLite) ---
# Get from https://turso.tech (turso db tokens create <db-name>)
TURSO_DATABASE_URL="libsql://your-database-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# For local dev you may use a local SQLite file instead:
# TURSO_DATABASE_URL="file:./local.db"
# TURSO_AUTH_TOKEN=""

# --- NextAuth ---
# Generate via:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-strong-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- Judge0 API (Code Execution) ---
# Sign up at https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL="https://judge0-ce.p.rapidapi.com"
JUDGE0_API_KEY="your-rapidapi-key"
JUDGE0_API_HOST="judge0-ce.p.rapidapi.com"

# --- Admin Bootstrap ---
# Used by seed script to create the first admin
ADMIN_EMAIL="admin@pybootcamp.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Super Admin"
